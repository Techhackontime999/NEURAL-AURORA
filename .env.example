# Required: AI provider for the puzzle generator (any OpenAI-compatible API)
# If not set, falls back to hardcoded static questions.
VITE_AI_API_BASE=https://openrouter.ai/api/v1
VITE_AI_API_KEY=your_api_key_here
VITE_AI_MODEL=openai/gpt-4o-mini

# Required for dynamic content: Supabase project URL and anon key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: AI voice model for TTS (Text-to-Speech) via OpenRouter (e.g. openai/tts-1)
# Uses browser SpeechSynthesis if empty.
VITE_VOICE_MODEL=openai/tts-1

# Optional: Jamendo API client ID for real background music
# Get a free key at https://devportal.jamendo.com
# If not set, falls back to Web Audio synth (ambient tones)
VITE_JAMENDO_CLIENT_ID=your_jamendo_client_id

# Required for YouTube Browse verification ("Channel Stream" mode): YouTube Data API v3 key
# Get a free key at https://console.cloud.google.com (enable YouTube Data API v3)
VITE_YOUTUBE_API_KEY=your_youtube_api_key
# Optional: Default channel ID for YouTube Browse (can also be set via admin panel)
# VITE_YOUTUBE_CHANNEL_ID=UC_your_channel_id
